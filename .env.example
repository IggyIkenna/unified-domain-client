# unified-domain-services - optional env vars
# Primary: Use GCP_PROJECT_ID
GCP_PROJECT_ID=your-gcp-project-id-here

# Backward compatibility (GCP SDK default)
# GOOGLE_CLOUD_PROJECT=${GCP_PROJECT_ID}

# -----------------------------------------------------------------------------
# GITHUB AUTHENTICATION (for local dev & CI)
# -----------------------------------------------------------------------------
# GitHub Personal Access Token for cloning private deps, quality gates.
# Create at: https://github.com/settings/tokens (repo scope)
# Local: add to .env or export GH_PAT=...; CI: add GH_PAT in repo Settings → Secrets
GH_PAT=
